# ============================================================
#  API Keys · hier eintragen, dann Datei nach .env kopieren
# ============================================================

GROQ_API_KEY=
ELEVENLABS_API_KEY=

# ============================================================
#  Pipeline-Modus
# ============================================================
# sequential  → wartet auf vollständige LLM-Antwort, dann TTS
# streaming   → Token-Streaming + Sentence-Splitter → TTS
PIPELINE_MODE=sequential

# ============================================================
#  LLM
# ============================================================
LLM_MODEL=openai/gpt-oss-20b
LLM_MAX_TOKENS=200
LLM_REASONING_EFFORT=low
LLM_TEMPERATURE=0.7
LLM_SYSTEM_PROMPT=Du bist ein hilfsbereiter Voice-Assistent. Antworte immer auf Deutsch, auch wenn die Eingabe in einer anderen Sprache ist. Antworte in 1-3 kurzen Sätzen.

# ============================================================
#  TTS · ElevenLabs
# ============================================================
TTS_MODEL=eleven_flash_v2_5
TTS_VOICE_ID=C4QktxZ39Uccr2xNdFHg
TTS_OUTPUT_FORMAT=pcm_24000
TTS_LANGUAGE_CODE=de

# ============================================================
#  VAD · FastRTC AlgoOptions
# ============================================================
VAD_PAUSE_DURATION=0.6
VAD_STARTED_TALKING=0.2
VAD_SPEECH_THRESHOLD=0.1
RTC_STUN_URLS=stun:stun.l.google.com:19302

# ============================================================
#  STT · Groq Whisper
# ============================================================
GROQ_STT_MODEL=whisper-large-v3-turbo

# ============================================================
#  Metrics
# ============================================================
METRICS_DB=/data/metrics.sqlite
